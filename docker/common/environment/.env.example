# Nginx Proxy
NGINX_CONTAINER=auth-proxy
NGINX_HTTPS_PORT=443

# Let's Encrypt
LETS_ENCRYPT_CONTAINER=auth-letsencrypt

# MySQL
MYSQL_CONTAINER=auth-mysql
MYSQL_DATABASE=authorization
MYSQL_USER=develop
MYSQL_PASSWORD="docker#DOCKER1234"
MYSQL_ROOT_PASSWORD="docker#DOCKER1234"
MYSQL_TZ=Asia/Tokyo
MYSQL_PORT=3306

# Redis
REDIS_CONTAINER=auth-redis
REDIS_PORT=6379

# MailHog
MAILHOG_CONTAINER=auth-mailhog
MAILHOG_PORT=8025

# RedisInsight
REDIS_INSIGHT_CONTAINER=auth-redisinsight
REDIS_INSIGHT_PORT=8001
