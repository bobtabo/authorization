# 環境名
APP_ENV=local

# サーバーポート
APP_PORT=8000

# フロントエンドURL（CORS許可 + Googleリダイレクト先）
FRONTEND_URL=http://localhost:3000

# クッキー有効期間（分）
STAFF_COOKIE_LIFETIME=60

# 通知一覧のデフォルト取得件数
NOTIFICATION_DEFAULT_LIMIT=10

# キャッシュPrefix
CACHE_PREFIX=Authorization Gateway

# DB接続情報
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=authorization
DB_USERNAME=develop
DB_PASSWORD="docker#DOCKER1234"

# Redis接続情報
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OAuth2クライアント設定
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=http://localhost:3000/function/python/auth/google/callback

# JWT キャッシュ有効期間（秒）
GATE_JWT_CACHE_TTL=1800
