# 環境名
APP_ENV=testing

# サーバーポート
APP_PORT=8080

# フロントエンドURL
FRONTEND_URL=http://localhost:3000

# クッキー有効期間（分）
STAFF_COOKIE_LIFETIME=60

# 通知一覧のデフォルト取得件数
NOTIFICATION_DEFAULT_LIMIT=10

# キャッシュPrefix
CACHE_PREFIX=

# DB接続情報（CI用: 127.0.0.1）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=authorization_test
DB_USERNAME=develop
DB_PASSWORD="docker#DOCKER1234"

# Redis接続情報（CI用: 127.0.0.1）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OAuth2クライアント設定
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# JWT設定
GATE_JWT_CACHE_TTL=1800

# メール設定
APP_NAME="Authorization Gateway"
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@example.com"
