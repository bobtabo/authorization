# アプリ名
APP_NAME=Authorization

# 環境名
APP_ENV=local

# 暗号鍵
APP_KEY=base64:N7b6fvlgGM1eZnX5HxNM50gASFL26OguBMmlpSoyycQ=

# デバッグ表示
APP_DEBUG=true

# アプリURL
APP_URL=https://apis.authorization-php.local

# ロケール
APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP

# メンテナンスモード保存先
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHPビルトインサーバーのワーカー数
# PHP_CLI_SERVER_WORKERS=4

# Bcryptのラウンド数
BCRYPT_ROUNDS=12

# ログ情報
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# DB接続情報
DB_CONNECTION=testing
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=authorization
DB_USERNAME=develop
DB_PASSWORD="docker#DOCKER1234"

# セッション情報
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ブロードキャスト設定
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# キャッシュ設定
CACHE_STORE=redis
# CACHE_PREFIX=

# Memcached接続情報
MEMCACHED_HOST=127.0.0.1

# Redis接続情報
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# メール設定
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="satoshi.nagashiba@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3設定
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# フロントエンドで使用する環境変数
VITE_APP_NAME="${APP_NAME}"

# OAuth2クライアント設定
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=https://apis.authorization-php.local/auth/google/callback
