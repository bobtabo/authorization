# 開発: /function/php/api → Next.js rewrites が Lambda ローカルサーバー経由でバックエンドへ中継（CORS 回避）
# 本番 Laravel 例: https://apis.authorization-php.dev/api（/v1 なし）
NEXT_PUBLIC_API_URL=/function/php/api

# API Gateway エミュレータのプロキシターゲット（make run-local で起動）
LAMBDA_PROXY_TARGET=http://localhost:8080

# PostcodeJP API
NEXT_PUBLIC_POSTCODE_API_KEY=your-postcode-api-key

# E2E テスト用（"1" に設定すると Google 認証をスキップ）
# NEXT_PUBLIC_E2E=1
