# 開発: 相対パス → Vite が VITE_API_PROXY_TARGET へプロキシ（CORS 回避）
# OpenAPI の servers が .../v1 を含む想定で /api/v1。バックエンドがルート直置きなら /api に変更。
VITE_API_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:8080

# Postcode JP（https://apis.postcode-jp.com/）— apiKey。Vite では envPrefix に POSTCODE_ を含めているためこの名前で import.meta.env に載る
POSTCODE_API_KEY=